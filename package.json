{
  "name": "x-timeline-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-first MCP server for X timeline and recent search analysis workflows.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "live:check": "tsx scripts/live-check.ts",
    "live:oauth:help": "tsx scripts/live-oauth-check.ts --help",
    "live:oauth:check": "tsx scripts/live-oauth-check.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "jose": "^5.9.6",
    "pg": "^8.13.1",
    "pino": "^9.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
