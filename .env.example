# Core server
PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
MCP_BASE_PATH=/mcp
LOG_LEVEL=info

# Session store
SESSION_STORE_MODE=postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/x_timeline_mcp

# IMPORTANT:
# Check src/auth/sessionCrypto.ts to confirm expected encoding format
# before pasting a real value here.
SESSION_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_KEY_IN_EXPECTED_FORMAT

# X OAuth / app config
X_CLIENT_ID=REPLACE_WITH_X_CLIENT_ID
X_CLIENT_SECRET=REPLACE_WITH_X_CLIENT_SECRET_IF_USED
X_REDIRECT_URI=http://127.0.0.1:3000/oauth/x/callback
X_SCOPES=tweet.read users.read offline.access

# X auth endpoints
X_OAUTH_AUTHORIZE_URL=https://x.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token
X_ISSUER=https://api.x.com
X_AUDIENCE=api.x.com

# Token verification mode
# Choose one:
# strict_jwt | opaque_trust_session | dev_skip_verify
X_TOKEN_VERIFICATION_MODE=opaque_trust_session

# Optional, only if your public/noauth read tools should work
X_APP_BEARER_TOKEN=REPLACE_WITH_X_APP_BEARER_TOKEN

# Optional, only if strict_jwt in your implementation needs it
# X_JWKS_URL=REPLACE_IF_YOUR_CODE_EXPECTS_IT

# Live harness
LIVE_TEST_BASE_URL=http://127.0.0.1:3000
LIVE_TEST_MCP_PATH=/mcp
LIVE_TEST_HEALTH_PATH=/healthz
LIVE_TEST_ENABLE_PUBLIC_X=true
LIVE_TEST_ENABLE_OAUTH_MANUAL=true
LIVE_TEST_QUERY=openai
LIVE_TEST_TIMEOUT_MS=10000
LIVE_TEST_VERBOSE=false
