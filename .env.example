# Core server
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
MCP_BASE_PATH=/mcp
LOG_LEVEL=info

# X OAuth / app config
X_CLIENT_ID=replace-with-x-client-id
# X_CLIENT_SECRET is optional in this scaffold and only used if your X app requires confidential-client exchange.
# X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/oauth/x/callback
X_SCOPES=tweet.read users.read offline.access
X_OAUTH_AUTHORIZE_URL=https://twitter.com/i/oauth2/authorize
X_OAUTH_TOKEN_URL=https://api.x.com/2/oauth2/token
X_ISSUER=https://api.x.com
X_AUDIENCE=api.x.com
# Optional. Needed only if access tokens are JWT and signature verification is enabled.
# X_JWKS_URL=https://api.x.com/2/oauth2/jwks

# Public app-only auth for public/optional-auth tools
# Required if you want unauthenticated callers to use public tools.
X_APP_BEARER_TOKEN=

# Session persistence and encryption
# Default posture is postgres-backed durability. Use in_memory only for local/dev workflows.
SESSION_STORE_MODE=postgres
# 32-byte AES-256-GCM key encoded as 64 hex characters.
SESSION_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# Required when SESSION_STORE_MODE=postgres.
# DATABASE_URL=postgres://user:pass@localhost:5432/x_timeline_mcp

# Pending OAuth state TTL (seconds)
OAUTH_PENDING_AUTH_TTL_SECONDS=600

# Token verification mode
# strict_jwt: require JWT signature/issuer/audience verification via X_JWKS_URL
# opaque_trust_session: trust opaque tokens only when bound to a live server-side session and scopes/expiry check pass
# dev_skip_verify: skip token-claim verification for local development only
X_TOKEN_VERIFICATION_MODE=strict_jwt
# Linked session TTL (seconds)
TOKEN_SESSION_TTL_SECONDS=86400
